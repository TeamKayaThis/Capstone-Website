// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== ENUMS ====================

enum UserRole {
  user
  admin
}

enum FilmType {
  trailer
  full
}

enum QuestionType {
  text
  rating
  choice
}

enum TriggerType {
  during
  after
}

// ==================== CORE TABLES ====================

model User {
  id                    String                @id @default(cuid())
  email                 String                @unique
  password_hash         String
  first_name            String?
  last_name             String?
  role                  UserRole              @default(user)
  is_active             Boolean               @default(true)
  is_email_verified     Boolean               @default(false)
  avatar_url            String?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt
  deleted_at            DateTime?

  // Relations
  password_resets       PasswordReset[]
  email_verifications   EmailVerification[]
  film_progress         UserFilmProgress[]
  survey_responses      SurveyResponse[]
  feedback              Feedback[]
  admin_logs            AdminLog[]            @relation("AdminLogs")

  @@index([email])
  @@index([role])
}

model PasswordReset {
  id                    String                @id @default(cuid())
  user_id               String
  token                 String                @unique
  expires_at            DateTime
  used_at               DateTime?
  created_at            DateTime              @default(now())

  // Relations
  user                  User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model EmailVerification {
  id                    String                @id @default(cuid())
  user_id               String
  token                 String                @unique
  expires_at            DateTime
  verified_at           DateTime?
  created_at            DateTime              @default(now())

  // Relations
  user                  User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ==================== FILM TABLES ====================

model Film {
  id                    String                @id @default(cuid())
  title                 String
  description           String?
  type                  FilmType
  duration_seconds      Int?
  thumbnail_url         String?
  video_url             String?
  video_storage_key     String?               // Supabase Storage path
  is_published          Boolean               @default(false)
  release_date          DateTime?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt

  // Relations
  user_progress         UserFilmProgress[]
  surveys               Survey[]

  @@index([type])
  @@index([is_published])
}

model UserFilmProgress {
  id                    String                @id @default(cuid())
  user_id               String
  film_id               String
  seconds_watched       Int                   @default(0)
  percentage_watched    Int                   @default(0)
  completed             Boolean               @default(false)
  started_at            DateTime              @default(now())
  last_watched_at       DateTime              @updatedAt
  completed_at          DateTime?

  // Relations
  user                  User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  film                  Film                  @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@unique([user_id, film_id])
  @@index([user_id])
  @@index([film_id])
}

// ==================== SURVEY TABLES ====================

model Survey {
  id                    String                @id @default(cuid())
  film_id               String
  title                 String
  description           String?
  trigger_type          TriggerType
  trigger_time_seconds  Int?                  // For 'during' type
  is_active             Boolean               @default(true)
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt

  // Relations
  film                  Film                  @relation(fields: [film_id], references: [id], onDelete: Cascade)
  questions             SurveyQuestion[]
  responses             SurveyResponse[]

  @@index([film_id])
}

model SurveyQuestion {
  id                    String                @id @default(cuid())
  survey_id             String
  question_text         String
  question_type         QuestionType
  order                 Int
  is_required           Boolean               @default(true)
  options               String?               // JSON array for choice type
  created_at            DateTime              @default(now())

  // Relations
  survey                Survey                @relation(fields: [survey_id], references: [id], onDelete: Cascade)
  answers               SurveyAnswer[]

  @@index([survey_id])
}

model SurveyAnswer {
  id                    String                @id @default(cuid())
  question_id           String
  label                 String
  value                 String                // For rating: "1-5", for choice: option value
  order                 Int                   @default(0)

  // Relations
  question              SurveyQuestion        @relation(fields: [question_id], references: [id], onDelete: Cascade)
  responses             SurveyResponse[]

  @@index([question_id])
}

model SurveyResponse {
  id                    String                @id @default(cuid())
  user_id               String
  survey_id             String
  question_id           String
  answer_id             String?
  custom_response       String?               // For text answers
  created_at            DateTime              @default(now())

  // Relations
  user                  User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  survey                Survey                @relation(fields: [survey_id], references: [id], onDelete: Cascade)
  answer                SurveyAnswer?         @relation(fields: [answer_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([survey_id])
}

// ==================== FEEDBACK TABLES ====================

model Feedback {
  id                    String                @id @default(cuid())
  user_id               String
  title                 String
  message               String
  rating                Int?                  // Optional: 1-5 star rating
  is_resolved           Boolean               @default(false)
  admin_response        String?
  created_at            DateTime              @default(now())
  updated_at            DateTime              @updatedAt

  // Relations
  user                  User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_resolved])
}

// ==================== ADMIN AUDIT ====================

model AdminLog {
  id                    String                @id @default(cuid())
  admin_id              String
  action                String                // "create", "update", "delete", "ban", "verify"
  resource_type         String                // "user", "film", "survey", "feedback"
  resource_id           String
  changes               String?               // JSON of before/after
  ip_address            String?
  created_at            DateTime              @default(now())

  // Relations
  admin                 User                  @relation("AdminLogs", fields: [admin_id], references: [id], onDelete: Cascade)

  @@index([admin_id])
  @@index([resource_type])
  @@index([created_at])
}
